{
  "expo": {
    "name": "RunLab",
    "slug": "runlab",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "runlab",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.runlab.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RunLab usa a tua localização para rastrear corridas.",
        "NSHealthShareUsageDescription": "RunLab acede aos dados de saúde para personalizar o teu plano de treino.",
        "NSHealthUpdateUsageDescription": "RunLab guarda os teus treinos no Apple Health."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.runlab.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACTIVITY_RECOGNITION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0A0F"
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF6B35",
          "androidMode": "default",
          "androidCollapsedTitle": "%(count)s treinos pendentes"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fd7fbe32-ac29-42c2-afe1-50076db8aa8a"
      }
    }
  }
}
